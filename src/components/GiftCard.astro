---
import { urlFor } from '../sanity/image';
import type { Gift } from '../sanity/queries';

interface Props {
  gift: Gift;
}

const { gift } = Astro.props;

const formattedPrice =
  typeof gift.priceApprox === 'number'
    ? new Intl.NumberFormat('ca-ES', {
        style: 'currency',
        currency: 'EUR',
        maximumFractionDigits: 0,
      }).format(gift.priceApprox)
    : null;

const imageUrl = gift.image
  ? urlFor(gift.image).width(800).height(800).fit('crop').auto('format').url()
  : null;

const detailHref = gift.slug?.current ? `/regalo/${gift.slug.current}` : null;
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-black/5 transition hover:shadow-md"
>
  <div class="aspect-square overflow-hidden bg-[var(--color-blush)]/40">
    {
      imageUrl ? (
        <img
          src={imageUrl}
          alt={gift.title}
          loading="lazy"
          decoding="async"
          width="800"
          height="800"
          class="h-full w-full object-cover transition group-hover:scale-[1.02]"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center text-4xl text-[var(--color-ink)]/30">
          🎁
        </div>
      )
    }
  </div>

  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-lg font-semibold leading-snug">
        {detailHref ? <a href={detailHref} class="hover:underline">{gift.title}</a> : gift.title}
      </h3>
      {
        formattedPrice && (
          <span class="shrink-0 rounded-full bg-[var(--color-mint)] px-2.5 py-1 text-xs font-medium">
            {formattedPrice}
          </span>
        )
      }
    </div>

    {
      gift.description && (
        <p class="whitespace-pre-line text-sm leading-relaxed text-[var(--color-ink)]/75">
          {gift.description}
        </p>
      )
    }

    {
      gift.notes && (
        <p class="rounded-lg bg-[var(--color-cream)] px-3 py-2 text-xs italic text-[var(--color-ink)]/60">
          {gift.notes}
        </p>
      )
    }

    <a
      href={gift.externalUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-auto inline-flex items-center justify-center rounded-full bg-[var(--color-ink)] px-4 py-2 text-sm font-medium text-[var(--color-cream)] transition hover:bg-[var(--color-ink)]/85"
    >
      Comprar →
    </a>
  </div>
</article>
