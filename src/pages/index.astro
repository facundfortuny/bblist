---
import Base from '../layouts/Base.astro';
import Registry, { type RegistryGift } from '../components/Registry.tsx';
import { sanityClient } from 'sanity:client';
import { urlFor } from '../sanity/image';
import { availableGiftsQuery, type Gift } from '../sanity/queries';
import '../styles/registry.css';

const gifts = await sanityClient.fetch<Gift[]>(availableGiftsQuery);

// Map Sanity documents to the shape the registry island expects.
const registryGifts: RegistryGift[] = gifts.map((gift) => ({
  id: gift._id,
  title: gift.title,
  category: gift.category ?? 'otros',
  price: typeof gift.priceApprox === 'number' ? gift.priceApprox : null,
  description: gift.description,
  notes: gift.notes,
  url: gift.externalUrl,
  status: gift.status,
  imageUrl: gift.image
    ? urlFor(gift.image).width(800).fit('max').auto('format').url()
    : null,
}));
---

<Base>
  <Registry client:load gifts={registryGifts} />
</Base>
