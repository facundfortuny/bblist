---
import Base from '../../layouts/Base.astro';
import { sanityClient } from 'sanity:client';
import { urlFor } from '../../sanity/image';
import { catFor } from '../../sanity/categories';
import {
  giftBySlugQuery,
  giftSlugsQuery,
  type Gift,
} from '../../sanity/queries';
import '../../styles/registry.css';

export async function getStaticPaths() {
  const slugs = await sanityClient.fetch<string[]>(giftSlugsQuery);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const gift = await sanityClient.fetch<Gift | null>(giftBySlugQuery, { slug });

if (!gift) {
  return Astro.redirect('/');
}

const cat = catFor(gift.category);

const formattedPrice =
  typeof gift.priceApprox === 'number'
    ? new Intl.NumberFormat('ca-ES', {
        style: 'currency',
        currency: 'EUR',
        maximumFractionDigits: 0,
      }).format(gift.priceApprox)
    : null;

const imageUrl = gift.image
  ? urlFor(gift.image).width(1200).height(900).fit('crop').auto('format').url()
  : null;
---

<Base title={`${gift.title} · Llista de regals`} description={gift.description}>
  <div class="page">
    <main class="detail">
      <a href="/" class="detail-back">← Tornar a la llista</a>

      <div class="detail-grid">
        <figure class="detail-art" style={`background: ${cat.accent}`}>
          {
            imageUrl ? (
              <img
                class="detail-photo"
                src={imageUrl}
                alt={gift.title}
                loading="lazy"
                decoding="async"
              />
            ) : (
              <svg viewBox="0 0 64 64" aria-hidden="true">
                <path
                  d="M32 12l6 13 14 1-11 9 4 14-13-8-13 8 4-14-11-9 14-1z"
                  fill={cat.ink}
                  opacity="0.14"
                />
                <path
                  d="M32 12l6 13 14 1-11 9 4 14-13-8-13 8 4-14-11-9 14-1z"
                  fill="none"
                  stroke={cat.ink}
                  stroke-width="3.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            )
          }
          <span class="detail-cat" style={`color: ${cat.ink}`}>{cat.label}</span>
        </figure>

        <div class="detail-info">
          <span class="eyebrow">Llista de naixement</span>
          <h1 class="detail-title">{gift.title}</h1>
          {formattedPrice && <span class="detail-price">{formattedPrice}</span>}

          {gift.description && <p class="detail-desc">{gift.description}</p>}

          {
            gift.notes && (
              <p class="detail-notes">
                <span class="detail-notes-k">Preferència:</span> {gift.notes}
              </p>
            )
          }

          <div class="detail-actions">
            <a
              class="btn btn-primary"
              href={gift.externalUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Veure on comprar-ho →
            </a>
            <a class="btn btn-ghost" href="/">Tornar</a>
          </div>
        </div>
      </div>
    </main>
  </div>
</Base>
